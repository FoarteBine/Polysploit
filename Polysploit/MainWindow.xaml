<Window x:Class="Polysploit.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Polysploit" Height="600" Width="900" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="#0F0F13"
        Foreground="#E4E4E7">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" CornerRadius="0" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Background="#16161D" BorderBrush="#27272A" BorderThickness="0,0,0,1"
                MouseLeftButtonDown="Toolbar_MouseDown">
            <DockPanel>
                <!-- Window controls: far right -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,4,0" VerticalAlignment="Center">
                    <Button x:Name="MinimizeBtn" Content="&#x2500;" Width="32" Height="22"
                            Background="Transparent" Foreground="#A1A1AA" BorderThickness="0"
                            FontSize="12" Click="Minimize_Click"/>
                    <Button x:Name="CloseBtn" Content="&#x2715;" Width="32" Height="22"
                            Background="Transparent" Foreground="#A1A1AA" BorderThickness="0"
                            FontSize="11" Click="Close_Click"/>
                </StackPanel>

                <!-- Tool buttons -->
                <StackPanel Orientation="Horizontal" Margin="4,0" VerticalAlignment="Center">
                    <TextBlock Text="  Polysploit" Foreground="#A855F7" FontSize="13" FontWeight="Bold"
                               VerticalAlignment="Center" Width="100"/>
                    <Button x:Name="OpenFileBtn" Content="Open File" Width="90" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="OpenFile_Click"/>
                    <Button x:Name="SaveFileBtn" Content="Save File" Width="90" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="SaveFile_Click"/>
                    <Button x:Name="ExecuteBtn" Content="Execute" Width="85" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="Execute_Click"/>
                    <Button x:Name="ExecuteFileBtn" Content="Execute File" Width="100" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="ExecuteFile_Click"/>
                    <Button x:Name="ClearBtn" Content="Clear" Width="70" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="Clear_Click"/>
                    <Button x:Name="ClientsBtn" Content="Clients" Width="80" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="Clients_Click"/>
                    <Button x:Name="UnloadBtn" Content="Unload" Width="90" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="Unload_Click"/>
                    <Button x:Name="AttachBtn" Content="Attach" Width="80" Height="26" Margin="2,0"
                            Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                            FontSize="11" Click="Attach_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 Editor -->
        <Border Grid.Row="1" Background="#1E1E28">
            <wv2:WebView2 x:Name="MonacoEditor" />
        </Border>

        <!-- Output Console -->
        <Border Grid.Row="2" Background="#121218" BorderBrush="#27272A" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="#1A1A24" Padding="6,1">
                    <TextBlock Text="Output" Foreground="#71717A" FontSize="11"/>
                </Border>
                <TextBox x:Name="OutputBox" Grid.Row="1"
                         Background="#121218" Foreground="#22C55E" FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </Grid>
        </Border>
    </Grid>
</Window>
