<Window x:Class="Polysploit.ClientsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Clients" Height="350" Width="450"
        WindowStartupLocation="CenterOwner"
        Background="#0F0F13" Foreground="#E4E4E7"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Select clients to attach:" FontSize="13" Margin="0,0,0,8"/>

        <ListBox x:Name="ClientsList" Grid.Row="1"
                 Background="#1A1A24" BorderBrush="#27272A" BorderThickness="1"
                 Foreground="#E4E4E7" FontSize="12"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 SelectionMode="Extended">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        BorderThickness="0" Padding="4,2">
                                    <ContentPresenter/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#27272A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Ellipse x:Name="StatusDot" Grid.Column="0" Width="10" Height="10"
                                 Fill="{Binding StatusColor}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <CheckBox Grid.Column="1" IsChecked="{Binding IsSelected}"
                                  Content="{Binding DisplayText}"
                                  Foreground="#E4E4E7" FontSize="12"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="OK" Width="80" Height="28" Margin="0,0,6,0"
                    Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                    FontSize="12" Click="OK_Click"/>
            <Button Content="Cancel" Width="80" Height="28"
                    Background="#3B3B4D" Foreground="#E4E4E7" BorderThickness="0"
                    FontSize="12" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
